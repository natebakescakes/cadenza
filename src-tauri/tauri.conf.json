{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cadenza",
  "version": "0.0.6-alpha",
  "identifier": "com.cadenza.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cadenza",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5NEVGOTRGMTYxRDYxMjcKUldRbllSMFdUL2xPeWRWRFVkT0NrVnZWeTNHcWhrYnFySldzOTduejVSNXVFWHZDQk5mbmF6bFIK",
      "endpoints": [
        "https://github.com/natebakescakes/cadenza/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
